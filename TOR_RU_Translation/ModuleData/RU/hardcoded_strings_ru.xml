<?xml version="1.0" encoding="utf-8"?>
<!--
  Английские строки, ЗАШИТЫЕ в C# TOR_Core без {=stringId} — XML-локализация их не достаёт.
  Заменяются в рантайме через Harmony-prefix на MBTextManager.SetTextVariable.
  Новую утечку добавлять новой строкой <str/>, перекомпиляция DLL НЕ нужна (только перезапуск игры).
  prefix="true" — для строк с динамическим хвостом (заменяется начало, хвост сохраняется).
-->
<HardcodedStrings>
  <!-- Пещера троллей (TrollCaveMenuInit, LOCATION_DESCRIPTION) -->
  <str prefix="true"
       en="The cave is quiet. The trolls you slew still litter the ground, but their kind will return in time."
       ru="Пещера тиха. Перебитые вами тролли ещё устилают землю, но со временем их сородичи вернутся." />
  <str en="A dark cave emanates a terrible stench. Massive footprints and gnawed bones litter the entrance - clear signs of troll habitation."
       ru="Из тёмной пещеры исходит жуткая вонь. У входа — огромные следы и обглоданные кости, явные признаки логова троллей." />
  <str en="The cave is empty. No trolls dwell here currently."
       ru="Пещера пуста. Сейчас здесь не обитают тролли." />

  <!-- Хардкод new TextObject("...") — метки тултипов/разъяснений, названия источников дохода, типы поселений -->
  <str en="Brewers Guild" ru="Гильдия пивоваров" />
  <str en="Engineers Guild" ru="Гильдия инженеров" />
  <str en="Warriors Guild" ru="Гильдия воинов" />
  <str en="Squigherds" ru="Загоны сквигов" />
  <str en="Teef Bags" ru="Мешки зубьев" />
  <str en="Shiny Pile" ru="Куча блестяшек" />
  <str en="Oak of Ages" ru="Дуб Веков" />
  <str en="Dwarf Karak" ru="Дворфийский Карак" />
  <str en="Elven Metropolis" ru="Эльфийская метрополия" />
  <str en="Gift of Nurgle" ru="Дар Нургла" />
  <str en="Secular Seal" ru="Мирская печать" />
  <str en="It is time to declare war!" ru="Пора объявить войну!" />
  <str en="Summoned" ru="Призванный" />

  <!-- Пункт меню «Leave...» в raidingsite_menu (RaidingSiteMenuLogic): в TOR_Core токен
       записан как {tor_custom_settlement_menu_leave_str} БЕЗ '=', т.е. это переменная, а не
       {=id} — языковой XML его не достаёт. Чиним заменой всей сырой строки в ctor TextObject. -->
  <str en="{tor_custom_settlement_menu_leave_str}Leave..." ru="Уйти..." />
  <!-- Дуб Веков, экран дриад (OakOfAgesMenuLogic dryads_result): сырой литерал "back..." без {=id}. -->
  <str en="back..." ru="Назад..." />

  <!-- Книга-чертёж зачарования (EnchantmentBlueprintScript): сырые литералы в MultiSelectionInquiryData
       и TORCommon.Say — без {=id}. Заголовок/тело/кнопки чинятся через InquiryData_Constructor_Patch. -->
  <str en="Choose hero to learn new enchantment" ru="Выберите героя для изучения нового зачарования" />
  <str en="The scribing entails a powerful new enchantment effect for one of your party members to learn. Choose who will specialize in"
       ru="Переписывание дарует одному из членов вашего отряда мощный новый эффект зачарования. Выберите, кто им овладеет." />
  <str en="The manuscript is of no use for you." ru="Этот манускрипт вам бесполезен." />
  <str en="Accept" ru="Принять" scope="inquiry" />
  <str en="Cancel" ru="Отмена" scope="inquiry" />

  <!-- Пункт меню убежища «Assault hideout» (дневной штурм). Строки нет ни в одном XML/DLL TOR —
       вероятно строится в рантайме сторонним модом; ловим глобально через ctor TextObject. -->
  <str en="Assault hideout" ru="Штурмовать убежище" />

  <!-- Конкатенированные сообщения TORCommon.Say (regex; переменные-имена остаются на месте через $1/$2/$3) -->
  <str regex="^(.*) has already been used (\d+) time\(s\) by (.*)\.$"
       ru="$1 — уже использовано героем $3 ($2 раз)." />

  <!-- ======== scope="tooltip": метки TooltipProperty (ChivalryHelper, TORMapInfoVMExtension,
       ForestHarmonyHelper, TORExtendedInfoHelper). Сырые литералы в конструкторе TooltipProperty —
       не проходят ни через TextObject, ни через MBTextManager; ловятся TooltipPropertyTranslationPatch.
       Хвостовые ": "/" " нормализуются автоматически — достаточно базовой формы. ======== -->
  <str en="Morale" ru="Мораль" scope="tooltip" />
  <str en="Knightly wages" ru="Жалованье рыцарей" scope="tooltip" />
  <str en="Gain extra  Chivalry everyday" ru="Доп. Рыцарство ежедневно" scope="tooltip" />
  <str en="Next Rank" ru="Следующий ранг" scope="tooltip" />
  <str en="Required Chivalry" ru="Нужно Рыцарства" scope="tooltip" />
  <str en="Daily Change" ru="Дневное изменение" scope="tooltip" />
  <str en="You are a vampire, you are your own god" ru="Вы вампир — вы сами себе бог" scope="tooltip" />
  <str en="You are one with the forest" ru="Вы едины с лесом" scope="tooltip" />
  <str en="Unit Attributes" ru="Атрибуты юнита" scope="tooltip" />
  <str en="Health" ru="Здоровье" scope="tooltip" />
  <str en="Wardsave" ru="Защитный оберег" scope="tooltip" />
  <str en="Damage Resistances" ru="Сопротивление урону" scope="tooltip" />
  <str en="Damage Amplification" ru="Усиление урона" scope="tooltip" />
  <str en="Party Speed" ru="Скорость отряда" scope="tooltip" />
  <str en="Total" ru="Итого" scope="tooltip" />
  <str en="Melee Damage" ru="Урон в ближнем бою" scope="tooltip" />
  <str en="Ranged Damage" ru="Урон в дальнем бою" scope="tooltip" />
  <str en="Lance/Spear Damage" ru="Урон копья/пики" scope="tooltip" />
  <!-- Имена enum DamageType — уходят в тултип юнита как ResistedDamageType.ToString();
       перевод по канону tor_damagetype.* -->
  <str en="Physical" ru="Физический" scope="tooltip" />
  <str en="Magical" ru="Магический" scope="tooltip" />
  <str en="Fire" ru="Огненный" scope="tooltip" />
  <str en="Holy" ru="Священный" scope="tooltip" />
  <str en="Lightning" ru="Электрический" scope="tooltip" />
  <str en="Frost" ru="Морозный" scope="tooltip" />

  <!-- Хардкод new TextObject("...") из свипа 2026-06-11: видимые игроку строки -->
  <str en="Runaway Parts" ru="Сбежавшие детали" />              <!-- название квеста инженера -->
  <str en="Altdorf" ru="Альтдорф" />                            <!-- переменная IMPERIALCAPITAL в диалоге компаньона -->
  <str en="AI Bonus" ru="Бонус ИИ" />                           <!-- TORClanPoliticsModel, строка пояснения -->
  <str en="Bonus" ru="Бонус" />                                 <!-- TORSettlementMilitiaModel -->
  <str en="Dwarf Mining Bonus" ru="Бонус дворфийской добычи" /> <!-- TORVillageProductionCalculatorModel -->
  <str en="Perks" ru="Перки" />                                 <!-- TORCharacterStatsModel -->
  <str en="vampire effect" ru="эффект вампира" />               <!-- TORSettlementLoyaltyModel -->
  <str en="not vampire" ru="не вампир" />                       <!-- TORSettlementLoyaltyModel -->
  <str en="variable test" ru="прочие эффекты" />                <!-- TORSettlementLoyaltyModel, отладочная метка в тултипе лояльности -->
</HardcodedStrings>
